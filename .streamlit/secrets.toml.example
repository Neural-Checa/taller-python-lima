# 1. Copia este archivo y renómbralo a:  secrets.toml   (en esta misma carpeta .streamlit/)
# 2. Pega tu API key gratuita de Groq: https://console.groq.com/keys
#    (login con Google o GitHub, "Create API Key" — sin tarjeta, sin crear proyecto)
# 3. NO subas secrets.toml a git (ya está en .gitignore).
#
# Al desplegar en Streamlit Community Cloud, pegas este mismo contenido
# en Settings > Secrets de la app (no subes el archivo).

GROQ_API_KEY = "pega-aqui-tu-api-key"
